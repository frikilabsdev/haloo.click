# ── Base de datos ─────────────────────────────────────────────────────────────
# Producción: usa Neon (https://neon.tech) — formato:
#   postgresql://user:pass@ep-xxx.us-east-1.aws.neon.tech/neondb?sslmode=require
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/postgres"

# ── NextAuth v5 ───────────────────────────────────────────────────────────────
# Genera con: openssl rand -base64 32
AUTH_SECRET="tu-secreto-de-al-menos-32-caracteres-aqui"

# URL de tu app (requerida en producción para protección CSRF)
# En Vercel se asigna automáticamente; ponla igual al dominio personalizado si usas uno
APP_URL="https://haloo.click"
NEXTAUTH_URL="https://haloo.click"

# ── WhatsApp del administrador (con código de país, sin +) ───────────────────
ADMIN_WHATSAPP="529711260809"

# ── Cloudinary (REQUERIDO en producción para subida de imágenes) ───────────────
# Crea cuenta gratuita en https://cloudinary.com
CLOUDINARY_CLOUD_NAME=""
CLOUDINARY_API_KEY=""
CLOUDINARY_API_SECRET=""

# ── Entorno ───────────────────────────────────────────────────────────────────
# Vercel lo setea automáticamente; no necesitas configurarlo manualmente
NODE_ENV="production"
