generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── USUARIOS (auth propio, sin Supabase Auth) ────────────────────────────────

model User {
  id        String     @id @default(cuid())
  email     String     @unique
  password  String     // bcrypt hash
  name      String?
  isAdmin   Boolean    @default(false)
  isActive  Boolean    @default(true)

  tenantUsers         TenantUser[]
  passwordResetTokens PasswordResetToken[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PasswordResetToken {
  id        String    @id @default(cuid())
  userId    String
  token     String    @unique
  expiresAt DateTime
  usedAt    DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  createdAt DateTime  @default(now())

  @@index([userId])
  @@index([token])
}

// ─── UBICACIONES (catálogo administrado por super admin) ──────────────────────

model State {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  order     Int      @default(0)
  isActive  Boolean  @default(true)

  cities  City[]
  tenants Tenant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model City {
  id       String  @id @default(cuid())
  stateId  String
  name     String
  slug     String
  isActive Boolean @default(true)

  state   State    @relation(fields: [stateId], references: [id], onDelete: Cascade)
  tenants Tenant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([stateId, slug])
  @@index([stateId])
}

// ─── TENANT ───────────────────────────────────────────────────────────────────

model Tenant {
  id          String       @id @default(cuid())
  slug        String       @unique
  name        String
  description String?
  logo        String?
  coverImage  String?
  type        String?      // ej: "tacos", "pizzas", "birrias"
  phone       String?
  whatsappNumber          String?
  whatsappMessageTemplate String?
  status      TenantStatus @default(PENDING)
  plan        TenantPlan   @default(BASIC)
  address         String?
  stateId         String?
  cityId          String?
  deliveryEnabled Boolean  @default(true)
  pickupEnabled   Boolean  @default(true)

  state State? @relation(fields: [stateId], references: [id])
  city  City?  @relation(fields: [cityId], references: [id])

  users         TenantUser[]
  categories    Category[]
  products      Product[]
  optionGroups  OptionGroup[]
  orders        Order[]
  deliveryZones DeliveryZone[]
  paymentConfig PaymentConfig?
  schedules     Schedule[]
  branches      Branch[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum TenantStatus {
  PENDING
  ACTIVE
  SUSPENDED
}

enum TenantPlan {
  BASIC
  PRO
}

// ─── USUARIOS DEL TENANT ──────────────────────────────────────────────────────

model TenantUser {
  id       String     @id @default(cuid())
  tenantId String
  userId   String
  role     TenantRole @default(STAFF)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([tenantId, userId])
  @@index([tenantId])
  @@index([userId])
}

enum TenantRole {
  OWNER
  MANAGER
  STAFF
}

// ─── SUCURSALES ───────────────────────────────────────────────────────────────

model Branch {
  id       String  @id @default(cuid())
  tenantId String
  name     String
  address  String?
  phone    String?
  isActive Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// ─── MENÚ ─────────────────────────────────────────────────────────────────────

model Category {
  id          String   @id @default(cuid())
  tenantId    String
  name        String
  description String?
  image       String?
  position    Int      @default(0)
  isActive    Boolean  @default(true)

  products Product[]
  tenant   Tenant    @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

model Product {
  id               String  @id @default(cuid())
  tenantId         String
  categoryId       String
  name             String
  description      String?
  basePrice        Decimal @db.Decimal(10, 2)
  variantGroupName String? // Etiqueta del selector de variantes, ej: "Tamaño", "Sabor"
  position         Int     @default(0)
  isActive         Boolean @default(true)
  isAvailable      Boolean @default(true)

  images      ProductImage[]
  variants    ProductVariant[]    // Precio por variante (específico de este producto)
  complements ProductComplement[] // Extras/complementos de la biblioteca compartida
  suggestions ProductSuggestion[] @relation("ProductSuggestions") // Suelen comprarse juntos
  suggestedIn ProductSuggestion[] @relation("SuggestedIn")
  orderItems  OrderItem[]
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
  category    Category @relation(fields: [categoryId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
  @@index([categoryId])
}

model ProductImage {
  id        String @id @default(cuid())
  productId String
  url       String
  position  Int    @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ─── VARIANTES (específicas de un producto, REEMPLAZAN basePrice) ─────────────

model ProductVariant {
  id          String  @id @default(cuid())
  productId   String
  name        String  // ej: "Chica", "Mediana", "Grande"
  price       Decimal @db.Decimal(10, 2)
  isAvailable Boolean @default(true)
  position    Int     @default(0)

  product Product @relation(fields: [productId], references: [id], onDelete: Cascade)

  @@index([productId])
}

// ─── COMPLEMENTOS (biblioteca compartida de extras/opciones por tenant) ───────

model OptionGroup {
  id           String  @id @default(cuid())
  tenantId     String
  name         String   // Nombre público (lo ve el cliente en el menú)
  internalName String?  // Etiqueta interna solo visible en el dashboard para diferenciar grupos similares
  description  String?
  isVariant    Boolean @default(false)  // si true, la opción elegida REEMPLAZA el basePrice
  required     Boolean @default(false)
  multiple     Boolean @default(false)
  min          Int     @default(0)
  max          Int?
  position     Int     @default(0)

  // Visibilidad condicional: aparece si se selecciona cierta opción
  showIfOptionId String?
  showIfOption   Option? @relation("ConditionalGroups", fields: [showIfOptionId], references: [id])

  options     Option[]
  complements ProductComplement[]
  tenant      Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([tenantId])
}

// Tabla puente producto ↔ complemento (grupo de opciones compartido)
model ProductComplement {
  id            String @id @default(cuid())
  productId     String
  optionGroupId String
  position      Int    @default(0)

  product     Product     @relation(fields: [productId], references: [id], onDelete: Cascade)
  optionGroup OptionGroup @relation(fields: [optionGroupId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([productId, optionGroupId])
  @@index([productId])
  @@index([optionGroupId])
}

model Option {
  id            String  @id @default(cuid())
  optionGroupId String
  name          String
  description   String?
  price         Decimal @db.Decimal(10, 2) @default(0)
  isAvailable   Boolean @default(true)
  position      Int     @default(0)

  optionGroup       OptionGroup   @relation(fields: [optionGroupId], references: [id], onDelete: Cascade)
  conditionalGroups OptionGroup[] @relation("ConditionalGroups")

  @@index([optionGroupId])
}

// ─── SUGERENCIAS "SUELEN COMPRARSE JUNTOS" ───────────────────────────────────

// Tabla puente producto ↔ producto sugerido
model ProductSuggestion {
  id                 String @id @default(cuid())
  productId          String
  suggestedProductId String
  position           Int    @default(0)

  product          Product @relation("ProductSuggestions", fields: [productId], references: [id], onDelete: Cascade)
  suggestedProduct Product @relation("SuggestedIn",        fields: [suggestedProductId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@unique([productId, suggestedProductId])
  @@index([productId])
  @@index([suggestedProductId])
}

// ─── HORARIOS ─────────────────────────────────────────────────────────────────

model Schedule {
  id        String  @id @default(cuid())
  tenantId  String
  dayOfWeek Int     // 0=Domingo … 6=Sábado
  openTime  String  // "09:00"
  closeTime String  // "22:00"
  isActive  Boolean @default(true)

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@unique([tenantId, dayOfWeek])
  @@index([tenantId])
}

// ─── PAGOS ────────────────────────────────────────────────────────────────────

model PaymentConfig {
  id              String  @id @default(cuid())
  tenantId        String  @unique
  cashEnabled     Boolean @default(true)
  transferEnabled Boolean @default(false)
  cardEnabled     Boolean @default(false)

  bankName      String?
  clabe         String?
  accountNumber String?
  accountHolder String?
  reference     String?

  tenant Tenant @relation(fields: [tenantId], references: [id], onDelete: Cascade)
}

// ─── ZONAS DE ENTREGA ─────────────────────────────────────────────────────────

model DeliveryZone {
  id           String  @id @default(cuid())
  tenantId     String
  name         String
  cost         Decimal @db.Decimal(10, 2) @default(0)
  isFree       Boolean @default(false)
  isThirdParty Boolean @default(false)
  polygon      Json?   // GeoJSON Polygon
  isActive     Boolean @default(true)

  orders Order[]
  tenant Tenant  @relation(fields: [tenantId], references: [id], onDelete: Cascade)

  @@index([tenantId])
}

// ─── PEDIDOS ──────────────────────────────────────────────────────────────────

model Order {
  id            String @id @default(cuid())
  tenantId      String
  orderNumber   String
  // Token aleatorio para tracking público — usar este en URLs, NO el id
  trackingToken String @unique @default(dbgenerated("gen_random_uuid()")) @db.Uuid

  customerName     String
  customerPhone    String
  customerWhatsapp String?

  deliveryType   DeliveryType
  address        String?
  addressRef     String?
  housingType    String?
  lat            Float?
  lng            Float?
  deliveryZoneId String?
  deliveryCost   Decimal?     @db.Decimal(10, 2)

  paymentMethod PaymentMethod
  status        OrderStatus   @default(PENDING)

  subtotal Decimal @db.Decimal(10, 2)
  total    Decimal @db.Decimal(10, 2)
  notes    String?

  whatsappSent Boolean @default(false)

  items        OrderItem[]
  deliveryZone DeliveryZone? @relation(fields: [deliveryZoneId], references: [id])
  tenant       Tenant        @relation(fields: [tenantId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([tenantId, orderNumber])
  @@index([tenantId])
  @@index([tenantId, status])
}

enum DeliveryType {
  DELIVERY
  PICKUP
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
}

enum OrderStatus {
  PENDING
  CONFIRMED
  PREPARING
  READY
  DELIVERED
  CANCELLED
}

model OrderItem {
  id          String  @id @default(cuid())
  orderId     String
  productId   String
  productName String
  quantity    Int
  unitPrice   Decimal @db.Decimal(10, 2)
  total       Decimal @db.Decimal(10, 2)
  notes       String?

  // Snapshot inmutable de opciones al momento del pedido
  selectedOptions Json @default("[]")

  order   Order   @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product @relation(fields: [productId], references: [id])

  @@index([orderId])
}
